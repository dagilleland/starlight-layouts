# Auto-detect text files and normalize line endings to LF in the repo.
# Git still checks them out using core.autocrlf / your local config.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files — force LF regardless of platform.
*.astro text eol=lf
*.ts text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.svg text eol=lf

# Lockfile: mark as generated so GitHub collapses its diffs and excludes it
# from language stats. Left mergeable normally — regenerate with `pnpm install`
# if a merge conflict shows up in it.
pnpm-lock.yaml linguist-generated=true

# Binary assets — never touch line endings, always diff as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
